# Copy this to .env.local and fill in your keys.
# .env.local is gitignored.

ANTHROPIC_API_KEY=


# Model selection. Defaults to claude-sonnet-4-6 to keep dev/testing cheap.
# For the demo recording, switch to claude-opus-4-7 for the warmest responses.
# SIMI_MODEL=claude-opus-4-7

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ^ Rachel voice by default. Swap for a warmer voice once you pick one in ElevenLabs.
# Good warm voices to try: "Sarah" (EXAVITQu4vr4xnSDxMaL), "Bella" (EXAVITQu4vr4xnSDxMaL)

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# In Vercel, set both of these. In browser, only VITE_GOOGLE_CLIENT_ID is used.
VITE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
